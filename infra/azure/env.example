# Azure resource names for the demo (copy to env.local and source before deploy scripts)
AZURE_RESOURCE_GROUP=igem-wiki-demo
AZURE_LOCATION=canadaeast
AZURE_CONTAINERAPP_ENV=igem-wiki-demo-env
AZURE_CONTAINERAPP_NAME=igem-payload-cms
AZURE_ACR_NAME=igempayloadcms
AZURE_STORAGE_ACCOUNT=igemwikidemostore
AZURE_FILE_SHARE=payload-data
AZURE_STATIC_WEB_APP_NAME=igem-wiki-demo

# After first deploy, paste the public URLs here for GitHub secrets
PAYLOAD_DEMO_URL=https://igem-payload-cms.xxxxx.canadaeast.azurecontainerapps.io
WIKI_DEMO_URL=https://your-wiki.azurestaticapps.net
